#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# ARO Proxy Manager
# redsocks + iptables + hostname + cron per user
#
# Proxy format:
#   host:port:user:pass
# Example:
#   snf5.tunproxy.com:65447:Dz8qWu:Cht0PT4D
#
# Menu:
# 1) Setup / doi proxy cho 1 user
# 2) Cai / cap nhat auto restart redsocks cho 1 user
# 3) Xoa auto restart redsocks cho 1 user
# 4) Xem cron auto restart hien tai
# 5) Test IP root va IP user
# 0) Thoat
#
# Luu y:
# - Config redsocks luu HOSTNAME, khong luu IP cung.
# - Auto restart theo tung user, khong restart tat ca cung luc.
# - Script chi restart redsocks-user, khong reboot VPS.
# ============================================================

BASE_PORT=12345
REDSOCKS_DIR="/etc/aro-proxy"
SYSTEMD_DIR="/etc/systemd/system"

require_root() {
  if [[ "${EUID}" -ne 0 ]]; then
    echo "Vui long chay bang root hoac sudo."
    exit 1
  fi
}

pause() {
  echo
  read -rp "Nhan Enter de tiep tuc..." _
}

list_normal_users() {
  awk -F: '$3>=1000 && $3<65534 {print $1}' /etc/passwd || true
}

validate_port() {
  local p="${1:-}"
  [[ "$p" =~ ^[0-9]+$ ]] && (( p >= 1 && p <= 65535 ))
}

validate_hour() {
  local h="${1:-}"
  [[ "$h" =~ ^[0-9]+$ ]] && (( h >= 0 && h <= 23 ))
}

validate_minute() {
  local m="${1:-}"
  [[ "$m" =~ ^[0-9]+$ ]] && (( m >= 0 && m <= 59 ))
}

user_exists() {
  id "$1" >/dev/null 2>&1
}

get_uid() {
  id -u "$1"
}

sanitize_user_tag() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_-'
}

ask_user() {
  echo "User hien co trong may:"
  list_normal_users | sed 's/^/ - /'
  echo
  read -rp "Nhap user, vi du aro2: " TARGET_USER
  TARGET_USER="${TARGET_USER:-}"

  if [[ -z "$TARGET_USER" ]]; then
    echo "Ban chua nhap user."
    return 1
  fi

  if ! user_exists "$TARGET_USER"; then
    echo "Khong tim thay user '$TARGET_USER'."
    echo "Hay tao user truoc bang aro-tool.sh."
    return 1
  fi

  USER_TAG="$(sanitize_user_tag "$TARGET_USER")"
  return 0
}

resolve_ipv4() {
  local host="$1"
  if [[ "$host" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
    echo "$host"
  else
    getent ahostsv4 "$host" | awk 'NR==1{print $1}'
  fi
}

next_free_port() {
  local p="$BASE_PORT"
  while ss -ltn 2>/dev/null | grep -q ":${p} "; do
    ((p++))
  done
  echo "$p"
}

ensure_dependencies() {
  export DEBIAN_FRONTEND=noninteractive
  apt update
  apt install -y redsocks iptables-persistent curl iproute2 cron
}

create_dirs() {
  mkdir -p "$REDSOCKS_DIR"
}

disable_ipv6_persistently() {
  local sysctl_file="/etc/sysctl.conf"

  grep -q '^net.ipv6.conf.all.disable_ipv6 = 1$' "$sysctl_file" || echo 'net.ipv6.conf.all.disable_ipv6 = 1' >> "$sysctl_file"
  grep -q '^net.ipv6.conf.default.disable_ipv6 = 1$' "$sysctl_file" || echo 'net.ipv6.conf.default.disable_ipv6 = 1' >> "$sysctl_file"
  grep -q '^net.ipv6.conf.lo.disable_ipv6 = 1$' "$sysctl_file" || echo 'net.ipv6.conf.lo.disable_ipv6 = 1' >> "$sysctl_file"

  sysctl -p >/dev/null || true
}

save_iptables() {
  mkdir -p /etc/iptables
  iptables-save > /etc/iptables/rules.v4
}

show_header() {
  clear || true
  echo "=============================================="
  echo " ARO Proxy Manager"
  echo " redsocks + hostname + cron/user"
  echo " Proxy: host:port:user:pass"
  echo "=============================================="
  echo
}

cron_marker_for_user() {
  local user_tag="$1"
  echo "ARO_AUTO_RESTART_REDSOCKS_${user_tag}"
}

install_cron_for_user() {
  local user_tag="$1"
  local service_name="redsocks-${user_tag}.service"
  local marker
  marker="$(cron_marker_for_user "$user_tag")"

  echo
  echo "Cai / cap nhat auto restart cho ${service_name}"
  echo "Nhap gio theo format 24h. Vi du:"
  echo "  Gio 3, phut 10  = 03:10 theo gio VPS"
  echo "  Gio 22, phut 40 = 22:40 theo gio VPS"
  echo
  read -rp "Nhap gio restart moi ngay (0-23): " RS_HOUR
  read -rp "Nhap phut restart moi ngay (0-59): " RS_MIN

  if ! validate_hour "$RS_HOUR"; then
    echo "Gio khong hop le."
    return 1
  fi

  if ! validate_minute "$RS_MIN"; then
    echo "Phut khong hop le."
    return 1
  fi

  local cron_line
  cron_line="${RS_MIN} ${RS_HOUR} * * * /bin/systemctl restart ${service_name} # ${marker}"

  (
    crontab -l 2>/dev/null | grep -v "${marker}" || true
    echo "${cron_line}"
  ) | crontab -

  echo
  echo "Da cai auto restart ${service_name} moi ngay luc ${RS_HOUR}:${RS_MIN}"
  echo "Chi restart rieng ${service_name}, khong restart cac user khac."
}

remove_cron_for_user() {
  local user_tag="$1"
  local service_name="redsocks-${user_tag}.service"
  local marker
  marker="$(cron_marker_for_user "$user_tag")"

  (
    crontab -l 2>/dev/null | grep -v "${marker}" || true
  ) | crontab -

  echo "Da xoa auto restart cho ${service_name}"
}

show_cron() {
  echo
  echo "Cron auto restart hien tai:"
  crontab -l 2>/dev/null | grep "ARO_AUTO_RESTART_REDSOCKS" || echo "Chua co cron auto restart redsocks."
}

parse_proxy_line() {
  local line="$1"

  IFS=':' read -r PROXY_HOST PROXY_PORT PROXY_USER PROXY_PASS EXTRA <<< "$line"

  if [[ -n "${EXTRA:-}" ]]; then
    echo "Proxy sai dinh dang. Pass khong duoc co dau ':'"
    return 1
  fi

  if [[ -z "${PROXY_HOST:-}" || -z "${PROXY_PORT:-}" || -z "${PROXY_USER:-}" || -z "${PROXY_PASS:-}" ]]; then
    echo "Proxy sai dinh dang."
    echo "Dung format: host:port:user:pass"
    return 1
  fi

  if ! validate_port "$PROXY_PORT"; then
    echo "Proxy port khong hop le."
    return 1
  fi

  return 0
}

setup_proxy_for_user() {
  if ! ask_user; then
    return 1
  fi

  echo
  echo "Nhap proxy theo dung dinh dang:"
  echo "host:port:user:pass"
  echo
  echo "Vi du:"
  echo "snf5.tunproxy.com:65447:Dz8qWu:Cht0PT4D"
  echo
  read -rp "Nhap proxy: " PROXY_LINE

  if ! parse_proxy_line "$PROXY_LINE"; then
    return 1
  fi

  PROXY_IP="$(resolve_ipv4 "$PROXY_HOST" || true)"
  if [[ -z "${PROXY_IP:-}" ]]; then
    echo "Khong resolve duoc IPv4 cho proxy host: $PROXY_HOST"
    echo "Hay kiem tra hostname/proxy provider."
    return 1
  fi

  USER_UID="$(get_uid "$TARGET_USER")"
  USER_TAG="$(sanitize_user_tag "$TARGET_USER")"
  LOCAL_PORT="$(next_free_port)"
  CONF_FILE="$REDSOCKS_DIR/redsocks-${USER_TAG}.conf"
  SERVICE_FILE="$SYSTEMD_DIR/redsocks-${USER_TAG}.service"
  CHAIN_NAME="REDSOCKS_${USER_TAG^^}"
  LOG_FILE="/var/log/redsocks-${USER_TAG}.log"

  echo
  echo ">>> Dang cai goi can thiet..."
  ensure_dependencies
  create_dirs

  echo ">>> User       : $TARGET_USER (UID $USER_UID)"
  echo ">>> Proxy host : $PROXY_HOST"
  echo ">>> Resolve IP : $PROXY_IP"
  echo ">>> Proxy port : $PROXY_PORT"
  echo ">>> Local port : $LOCAL_PORT"
  echo

  cat > "$CONF_FILE" <<EOF
base {
 log_debug = off;
 log_info = on;
 log = "file:${LOG_FILE}";
 daemon = off;
 redirector = iptables;
}

redsocks {
 local_ip = 127.0.0.1;
 local_port = ${LOCAL_PORT};

 ip = ${PROXY_HOST};
 port = ${PROXY_PORT};

 type = socks5;
 login = "${PROXY_USER}";
 password = "${PROXY_PASS}";
}
EOF

  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Redsocks for ${TARGET_USER}
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/sbin/redsocks -c ${CONF_FILE}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

  echo ">>> Dang tao / cap nhat iptables chain rieng..."
  iptables -t nat -D OUTPUT -p tcp -m owner --uid-owner "$USER_UID" -j "$CHAIN_NAME" 2>/dev/null || true
  iptables -t nat -F "$CHAIN_NAME" 2>/dev/null || true
  iptables -t nat -X "$CHAIN_NAME" 2>/dev/null || true

  iptables -t nat -N "$CHAIN_NAME"

  iptables -t nat -A "$CHAIN_NAME" -d 0.0.0.0/8 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -d 10.0.0.0/8 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -d 127.0.0.0/8 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -d 169.254.0.0/16 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -d 172.16.0.0/12 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -d 192.168.0.0/16 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -d 224.0.0.0/4 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -d 240.0.0.0/4 -j RETURN
  iptables -t nat -A "$CHAIN_NAME" -p tcp -j REDIRECT --to-ports "$LOCAL_PORT"

  iptables -t nat -A OUTPUT -p tcp -m owner --uid-owner "$USER_UID" -j "$CHAIN_NAME"

  echo ">>> Dang reload systemd va khoi dong service..."
  systemctl daemon-reload
  systemctl enable "redsocks-${USER_TAG}.service"
  systemctl restart "redsocks-${USER_TAG}.service"

  read -rp "Co tat IPv6 persistent cho may nay khong? (y/N): " DISABLE_IPV6
  DISABLE_IPV6="${DISABLE_IPV6:-N}"

  if [[ "$DISABLE_IPV6" =~ ^[Yy]$ ]]; then
    echo ">>> Dang tat IPv6 persistent..."
    disable_ipv6_persistently
  fi

  echo ">>> Dang luu iptables..."
  save_iptables

  echo
  read -rp "Co cai/cap nhat auto restart redsocks cho rieng user ${TARGET_USER} khong? (y/N): " WANT_CRON
  WANT_CRON="${WANT_CRON:-N}"
  if [[ "$WANT_CRON" =~ ^[Yy]$ ]]; then
    install_cron_for_user "$USER_TAG" || true
  fi

  echo
  echo ">>> Kiem tra nhanh service..."
  systemctl is-active "redsocks-${USER_TAG}.service" || true
  ss -tulpn | grep "$LOCAL_PORT" || true

  echo
  echo ">>> Test IP cua user ${TARGET_USER}:"
  su - "$TARGET_USER" -c 'curl -4 --max-time 20 -s https://api.ipify.org ; echo' || true

  echo
  echo ">>> Kiem tra config vua tao:"
  grep -E "ip =|port =|login =" "$CONF_FILE" || true

  echo
  echo "=============================================="
  echo "XONG."
  echo "User          : ${TARGET_USER}"
  echo "UID           : ${USER_UID}"
  echo "Proxy host    : ${PROXY_HOST}"
  echo "Resolve IP    : ${PROXY_IP}"
  echo "Proxy port    : ${PROXY_PORT}"
  echo "Local port    : ${LOCAL_PORT}"
  echo "Config file   : ${CONF_FILE}"
  echo "Service       : redsocks-${USER_TAG}.service"
  echo "iptables chain: ${CHAIN_NAME}"
  echo
  echo "Luu y:"
  echo "- Config redsocks dang luu hostname: ${PROXY_HOST}"
  echo "- ARO van se hien IP that sau khi hostname resolve."
  echo "- Khi proxy doi IP, restart service nay:"
  echo "  sudo systemctl restart redsocks-${USER_TAG}"
  echo "=============================================="
}

menu_install_cron() {
  if ! ask_user; then
    return 1
  fi
  install_cron_for_user "$USER_TAG"
}

menu_remove_cron() {
  if ! ask_user; then
    return 1
  fi
  remove_cron_for_user "$USER_TAG"
}

test_ip_user() {
  if ! ask_user; then
    return 1
  fi

  echo
  echo "ROOT IP / IP VPS goc:"
  curl -4 --max-time 15 -s https://api.ipify.org ; echo

  echo
  echo "${TARGET_USER} IP / IP proxy cua user:"
  su - "$TARGET_USER" -c 'curl -4 --max-time 20 -s https://api.ipify.org ; echo' || true

  echo
  echo "Service redsocks-${USER_TAG}:"
  systemctl status "redsocks-${USER_TAG}.service" --no-pager || true
}

main_menu() {
  require_root

  while true; do
    show_header
    echo "1) Setup / doi proxy cho 1 user"
    echo "2) Cai / cap nhat auto restart redsocks cho 1 user"
    echo "3) Xoa auto restart redsocks cho 1 user"
    echo "4) Xem cron auto restart hien tai"
    echo "5) Test IP root va IP user"
    echo "0) Thoat"
    echo
    read -rp "Chon: " CHOICE

    case "${CHOICE:-}" in
      1)
        setup_proxy_for_user || true
        pause
        ;;
      2)
        menu_install_cron || true
        pause
        ;;
      3)
        menu_remove_cron || true
        pause
        ;;
      4)
        show_cron
        pause
        ;;
      5)
        test_ip_user || true
        pause
        ;;
      0)
        echo "Thoat."
        exit 0
        ;;
      *)
        echo "Lua chon khong hop le."
        pause
        ;;
    esac
  done
}

main_menu "$@"
