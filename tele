#!/bin/bash

# ==================================================
# ARO TELEGRAM DAILY CHECK INSTALLER
# Chỉ check log + curl IP + gửi Telegram
# KHÔNG restart service
# KHÔNG sửa iptables
# KHÔNG sửa redsocks
# KHÔNG đụng proxy/watchdog cũ
# ==================================================

set -e

CHECK_SCRIPT="/root/aro-daily-check-telegram.sh"
CONFIG_FILE="/root/aro-telegram-check.conf"

echo "======================================"
echo " ARO TELEGRAM DAILY CHECK INSTALLER"
echo " Chỉ check, không ảnh hưởng hệ thống"
echo "======================================"
echo

read -rp "Nhập BOT_TOKEN Telegram: " BOT_TOKEN
read -rp "Nhập CHAT_ID Telegram: " CHAT_ID

if [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]]; then
  echo "Lỗi: BOT_TOKEN hoặc CHAT_ID đang trống."
  exit 1
fi

cat > "$CONFIG_FILE" <<EOF
BOT_TOKEN="$BOT_TOKEN"
CHAT_ID="$CHAT_ID"
EOF

chmod 600 "$CONFIG_FILE"

cat > "$CHECK_SCRIPT" <<'EOF'
#!/bin/bash

# ==================================================
# ARO DAILY TELEGRAM CHECK
# Chỉ đọc log + curl IP + gửi Telegram
# KHÔNG restart service
# KHÔNG sửa iptables
# KHÔNG sửa redsocks
# KHÔNG đụng proxy
# ==================================================

CONFIG_FILE="/root/aro-telegram-check.conf"
LOCKFILE="/tmp/aro-daily-check-telegram.lock"

if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "Thiếu config Telegram: $CONFIG_FILE"
  exit 1
fi

source "$CONFIG_FILE"

if [[ -z "$BOT_TOKEN" || -z "$CHAT_ID" ]]; then
  echo "Thiếu BOT_TOKEN hoặc CHAT_ID"
  exit 1
fi

# Chống chạy trùng
exec 9>"$LOCKFILE"
flock -n 9 || exit 0

DATE_NOW=$(date '+%Y-%m-%d %H:%M:%S')
HOSTNAME_NOW=$(hostname)

MSG="📊 ARO DAILY CHECK
VPS: $HOSTNAME_NOW
Time: $DATE_NOW

"

for home in /home/*; do
  [[ -d "$home" ]] || continue

  u=$(basename "$home")

  # Chỉ check user tồn tại thật
  id "$u" >/dev/null 2>&1 || continue

  LOG="$home/.local/share/com.aro.ARONetwork/logs/ARO Desktop.log"

  # Chỉ curl IP theo user, không sửa gì
  CURLIP=$(timeout 12 sudo -u "$u" curl -4 --max-time 10 -s https://api.ipify.org 2>/dev/null || true)
  CURLIP=${CURLIP:-NO_CURL}

  if [[ ! -f "$LOG" ]]; then
    MSG+="$u | curl=$CURLIP | AROIP=NO_LOG | connect=NO_LOG | uptime=0 | today=0
"
    continue
  fi

  AROIP=$(grep -o '"publicIp":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)
  CONN=$(grep -o '"connect":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)
  UPTIME=$(grep -o '"uptime":[0-9.]*' "$LOG" 2>/dev/null | tail -1 | cut -d':' -f2)
  TODAY=$(grep -o '"today":[0-9.]*' "$LOG" 2>/dev/null | tail -1 | cut -d':' -f2)

  AROIP=${AROIP:-"-"}
  CONN=${CONN:-"-"}
  UPTIME=${UPTIME:-0}
  TODAY=${TODAY:-0}

  MSG+="$u | curl=$CURLIP | AROIP=$AROIP | connect=$CONN | uptime=$UPTIME | today=$TODAY
"
done

# Nếu tin nhắn quá dài, cắt bớt để Telegram không lỗi
MAX_LEN=3900
if [[ ${#MSG} -gt $MAX_LEN ]]; then
  MSG="${MSG:0:$MAX_LEN}
...
Tin nhắn quá dài, đã cắt bớt."
fi

curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
  -d chat_id="$CHAT_ID" \
  --data-urlencode text="$MSG" >/dev/null 2>&1

exit 0
EOF

chmod +x "$CHECK_SCRIPT"

# Xóa cron cũ của chính script này, không đụng cron redsocks/watchdog
TMP_CRON="/tmp/aro_telegram_cron.tmp"
crontab -l 2>/dev/null | grep -v 'ARO_DAILY_RANDOM_TELEGRAM' > "$TMP_CRON" || true

# Random lần 1: 08:00 - 14:00
echo '0 8 * * * sleep $((RANDOM % 21600)) && /root/aro-daily-check-telegram.sh >/dev/null 2>&1 # ARO_DAILY_RANDOM_TELEGRAM_MORNING' >> "$TMP_CRON"

# Random lần 2: 18:00 - 23:00
echo '0 18 * * * sleep $((RANDOM % 18000)) && /root/aro-daily-check-telegram.sh >/dev/null 2>&1 # ARO_DAILY_RANDOM_TELEGRAM_EVENING' >> "$TMP_CRON"

crontab "$TMP_CRON"
rm -f "$TMP_CRON"

echo
echo "Đã cài xong."
echo
echo "File check:"
echo "$CHECK_SCRIPT"
echo
echo "File config:"
echo "$CONFIG_FILE"
echo
echo "Cron hiện tại:"
crontab -l | grep 'ARO_DAILY_RANDOM_TELEGRAM' || true
echo
echo "Đang gửi test Telegram..."
bash "$CHECK_SCRIPT"
echo "Xong. Nếu Telegram nhận tin là OK."
