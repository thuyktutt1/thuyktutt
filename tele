#!/bin/bash

# ==========================================================
# ARO Telegram Uptime Alert Menu
# Safe for GitHub: NO token inside this script.
# Token local file: /etc/aro-proxy/telegram.conf
# ==========================================================

CONFIG_FILE="/etc/aro-proxy/telegram.conf"
USERS_FILE="/etc/aro-proxy/uptime-users.conf"
STATE_PASS="/root/aro-uptime-pass.state"
STATE_DONE="/root/aro-uptime-all-done.state"
SCRIPT_PATH="/root/aro-uptime-telegram-alert.sh"

DEFAULT_USERS="aro aro1 aro2 aro3 aro4 aro5 aro6 aro7 aro8 aro9 aro10 aro11 aro12 aro13 aro14 aro15"

mkdir -p /etc/aro-proxy

load_users() {
  if [ -f "$USERS_FILE" ]; then
    USERS=$(cat "$USERS_FILE")
  else
    USERS="$DEFAULT_USERS"
  fi
}

send_telegram() {
  local msg="$1"

  if [ ! -f "$CONFIG_FILE" ]; then
    echo "❌ Chưa có Telegram config: $CONFIG_FILE"
    echo "Vào option 1 để nhập BOT_TOKEN + CHAT_ID."
    return 1
  fi

  source "$CONFIG_FILE"

  if [ -z "$BOT_TOKEN" ] || [ -z "$CHAT_ID" ]; then
    echo "❌ BOT_TOKEN hoặc CHAT_ID đang trống."
    echo "Vào option 1 để nhập lại."
    return 1
  fi

  curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
    -d chat_id="$CHAT_ID" \
    --data-urlencode text="$msg" >/dev/null
}

setup_telegram() {
  echo "=============================================="
  echo " Nhập Telegram BOT_TOKEN và CHAT_ID"
  echo " Token chỉ lưu local tại: $CONFIG_FILE"
  echo " Không đưa token lên GitHub."
  echo "=============================================="
  echo

  read -rp "BOT_TOKEN: " BOT_TOKEN
  read -rp "CHAT_ID: " CHAT_ID

  cat > "$CONFIG_FILE" <<EOF
BOT_TOKEN="$BOT_TOKEN"
CHAT_ID="$CHAT_ID"
EOF

  chmod 600 "$CONFIG_FILE"

  echo "✅ Đã lưu Telegram config."
}

test_telegram() {
  send_telegram "✅ Test Telegram OK

VPS: $(hostname)
Time: $(date)"
  echo "✅ Đã gửi tin test Telegram."
}

set_users() {
  echo "User hiện tại đang theo dõi:"
  if [ -f "$USERS_FILE" ]; then
    cat "$USERS_FILE"
  else
    echo "$DEFAULT_USERS"
  fi

  echo
  echo "Nhập danh sách user muốn theo dõi."
  echo "Ví dụ VPS 5 node:"
  echo "aro aro2 aro3 aro4 aro5"
  echo
  echo "Ví dụ VPS 15 node:"
  echo "aro aro1 aro2 aro3 aro4 aro5 aro6 aro7 aro8 aro9 aro10 aro11 aro12 aro13 aro14 aro15"
  echo

  read -rp "USERS: " NEW_USERS

  if [ -z "$NEW_USERS" ]; then
    echo "❌ Không được để trống."
    return
  fi

  echo "$NEW_USERS" > "$USERS_FILE"
  chmod 600 "$USERS_FILE"

  echo "✅ Đã lưu danh sách user theo dõi:"
  cat "$USERS_FILE"
}

show_users() {
  echo "=== USERS ĐANG THEO DÕI ==="
  if [ -f "$USERS_FILE" ]; then
    cat "$USERS_FILE"
  else
    echo "$DEFAULT_USERS"
  fi
}

check_uptime() {
  load_users

  touch "$STATE_PASS"

  TOTAL=0
  PASSED=0

  SUMMARY="📡 ARO UPTIME SUMMARY

VPS: $(hostname)
Time: $(date)

"

  for u in $USERS; do
    if id "$u" >/dev/null 2>&1; then
      TOTAL=$((TOTAL + 1))

      LOG="/home/$u/.local/share/com.aro.ARONetwork/logs/ARO Desktop.log"

      CURLIP=$(su - "$u" -c 'curl -4 --max-time 10 -s https://api.ipify.org ; echo' 2>/dev/null)
      AROIP=$(grep -o '"publicIp":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)
      CONN=$(grep -o '"connect":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)
      UPTIME=$(grep -o '"uptime":[0-9.]*' "$LOG" 2>/dev/null | tail -1 | cut -d':' -f2)
      TODAY=$(grep -o '"today":[0-9.]*' "$LOG" 2>/dev/null | tail -1 | cut -d':' -f2)

      [ -z "$CURLIP" ] && CURLIP="no_curl"
      [ -z "$AROIP" ] && AROIP="no_ip"
      [ -z "$CONN" ] && CONN="no_log"
      [ -z "$UPTIME" ] && UPTIME="0"
      [ -z "$TODAY" ] && TODAY="0"

      if [ "$UPTIME" != "0" ] && [ "$UPTIME" != "no_log" ]; then
        PASSED=$((PASSED + 1))
        STATUS="✅"
        KEY="$u|$AROIP"

        if ! grep -Fxq "$KEY" "$STATE_PASS"; then
          MSG="✅ ARO UPTIME PASS

VPS: $(hostname)
User: $u
Curl IP: $CURLIP
ARO IP: $AROIP
Connect: $CONN
Uptime: $UPTIME
Today: $TODAY
Time: $(date)

Giữ con này, không restart / không đổi proxy."

          send_telegram "$MSG"
          echo "$KEY" >> "$STATE_PASS"
        fi
      else
        if [ "$CONN" = "connected" ]; then
          STATUS="⚠️"
        else
          STATUS="❌"
        fi
      fi

      SUMMARY+="$STATUS $u | IP=$AROIP | connect=$CONN | uptime=$UPTIME | today=$TODAY
"
    else
      SUMMARY+="❌ $u | user not found
"
    fi
  done

  SUMMARY+="
Progress: $PASSED/$TOTAL pass uptime > 0"

  echo "$SUMMARY"

  if [ "$TOTAL" -gt 0 ] && [ "$PASSED" -eq "$TOTAL" ]; then
    if [ ! -f "$STATE_DONE" ]; then
      MSG="🎉 ARO HOÀN TẤT HẾT

VPS: $(hostname)
Tất cả user mục tiêu đã uptime > 0.

Progress: $PASSED/$TOTAL

$SUMMARY

Không restart / không đổi proxy các user đã pass."

      send_telegram "$MSG"
      touch "$STATE_DONE"
    fi
  fi
}

install_cron_hourly() {
  cp "$0" "$SCRIPT_PATH"
  chmod +x "$SCRIPT_PATH"

  crontab -l 2>/dev/null | grep -v "aro-uptime-telegram-alert.sh check" | crontab -
  (crontab -l 2>/dev/null; echo "0 * * * * $SCRIPT_PATH check >/dev/null 2>&1") | crontab -

  echo "✅ Đã cài cron check mỗi 1 tiếng."
  crontab -l | grep "aro-uptime-telegram-alert.sh"
}

remove_cron() {
  crontab -l 2>/dev/null | grep -v "aro-uptime-telegram-alert.sh check" | crontab -
  echo "✅ Đã xóa cron Telegram uptime alert."
}

reset_state() {
  rm -f "$STATE_PASS" "$STATE_DONE"
  echo "✅ Đã reset state. Lần check sau sẽ báo lại các user uptime > 0."
}

show_state() {
  echo "=== USER/IP ĐÃ BÁO PASS ==="
  cat "$STATE_PASS" 2>/dev/null || echo "Chưa có"

  echo
  echo "=== TRẠNG THÁI HOÀN TẤT HẾT ==="
  if [ -f "$STATE_DONE" ]; then
    echo "Đã báo hoàn tất hết."
  else
    echo "Chưa báo hoàn tất hết."
  fi
}

show_cron() {
  echo "=== CRON HIỆN TẠI ==="
  crontab -l 2>/dev/null || echo "Chưa có cron."
}

menu() {
  clear
  echo "=============================================="
  echo " ARO Telegram Uptime Alert"
  echo " Báo con nào uptime > 0 + báo hoàn tất hết"
  echo "=============================================="
  echo
  echo "1) Nhập / cập nhật Telegram BOT_TOKEN + CHAT_ID"
  echo "2) Test gửi Telegram"
  echo "3) Cài / đổi danh sách user cần theo dõi"
  echo "4) Xem danh sách user đang theo dõi"
  echo "5) Check uptime ngay"
  echo "6) Cài cron check mỗi 1 tiếng"
  echo "7) Xóa cron"
  echo "8) Xem state đã báo"
  echo "9) Reset state để báo lại từ đầu"
  echo "10) Xem cron hiện tại"
  echo "0) Thoát"
  echo
  read -rp "Chọn option: " CHOICE

  case "$CHOICE" in
    1) setup_telegram ;;
    2) test_telegram ;;
    3) set_users ;;
    4) show_users ;;
    5) check_uptime ;;
    6) install_cron_hourly ;;
    7) remove_cron ;;
    8) show_state ;;
    9) reset_state ;;
    10) show_cron ;;
    0) exit 0 ;;
    *) echo "❌ Option không hợp lệ." ;;
  esac

  echo
  read -rp "Nhấn Enter để quay lại menu..."
  menu
}

case "$1" in
  setup-telegram) setup_telegram ;;
  test-telegram) test_telegram ;;
  set-users) set_users ;;
  show-users) show_users ;;
  check) check_uptime ;;
  install-cron) install_cron_hourly ;;
  remove-cron) remove_cron ;;
  show-state) show_state ;;
  reset-state) reset_state ;;
  show-cron) show_cron ;;
  menu|"") menu ;;
  *)
    echo "Usage:"
    echo "$0 menu"
    echo "$0 setup-telegram"
    echo "$0 test-telegram"
    echo "$0 set-users"
    echo "$0 check"
    echo "$0 install-cron"
    echo "$0 reset-state"
    ;;
esac
