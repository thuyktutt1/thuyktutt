#!/usr/bin/env bash

# =========================================================
# ARO WATCHDOG FULL
#
# Logic:
#
# 1. CHECK CURLIP
#    FAIL -> restart redsocks
#
# 2. CURL OK
#    CHECK AROIP + connect
#
# 3. ARO FAIL
#    -> restart ARO GUI
#
# 4. FAIL nhiều lần
#    -> terminate-user
#    -> mở lại DISPLAY
#
# 5. FAIL quá nhiều
#    -> Telegram alert
#
# Designed for:
# - many aro users
# - many VPS
# - staggered timing
# =========================================================

set -u

BASE_DIR="/opt/aro-watchdog"
mkdir -p "$BASE_DIR"

TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""

send_tele() {

    local MSG="$1"

    [[ -z "$TELEGRAM_TOKEN" ]] && return
    [[ -z "$TELEGRAM_CHAT_ID" ]] && return

    curl -s -X POST \
        "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
        -d chat_id="$TELEGRAM_CHAT_ID" \
        -d text="$MSG" >/dev/null 2>&1
}

is_ip() {
    [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]
}

get_display() {

    local USER="$1"

    local DISP

    DISP=$(ps -fu "$USER" | grep Xorg | grep -o ':[0-9]\+' | head -1)

    [[ -z "$DISP" ]] && DISP=":10"

    echo "$DISP"
}

restart_aro() {

    local USER="$1"

    echo "Restart ARO: $USER"

    pkill -u "$USER" -f "/usr/bin/ARO" 2>/dev/null || true

    sleep 5

    local DISP
    DISP=$(get_display "$USER")

    su - "$USER" -c "export DISPLAY=$DISP && nohup /usr/bin/ARO >/dev/null 2>&1 &"

    sleep 30
}

hard_restart_user() {

    local USER="$1"

    echo "Hard restart session: $USER"

    loginctl terminate-user "$USER"

    sleep 15

    local DISP
    DISP=$(get_display "$USER")

    su - "$USER" -c "export DISPLAY=$DISP && nohup /usr/bin/ARO >/dev/null 2>&1 &"

    sleep 40
}

restart_redsocks() {

    local USER="$1"

    local SERVICE="redsocks-${USER}.service"

    echo "Restart redsocks: $SERVICE"

    systemctl restart "$SERVICE"

    sleep 20
}

check_user() {

    local USER="$1"

    local LOG
    LOG="/home/$USER/.local/share/com.aro.ARONetwork/logs/ARO Desktop.log"

    local STATE_FILE
    STATE_FILE="$BASE_DIR/${USER}.state"

    local FAIL=0

    [[ -f "$STATE_FILE" ]] && FAIL=$(cat "$STATE_FILE")

    echo
    echo "===== CHECKING $USER ====="

    local CURLIP
    CURLIP=$(su - "$USER" -c 'curl -4 --max-time 15 -s https://api.ipify.org' 2>/dev/null)

    local AROIP
    AROIP=$(grep -o '"publicIp":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)

    local CONN
    CONN=$(grep -o '"connect":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)

    echo "CURLIP : $CURLIP"
    echo "AROIP  : $AROIP"
    echo "CONNECT: $CONN"

    # =====================================================
    # CURL FAIL
    # =====================================================

    if ! is_ip "$CURLIP"; then

        echo
        echo "CURL FAIL"

        restart_redsocks "$USER"

        CURLIP=$(su - "$USER" -c 'curl -4 --max-time 15 -s https://api.ipify.org' 2>/dev/null)

        if ! is_ip "$CURLIP"; then

            FAIL=$((FAIL + 1))

            echo "$FAIL" > "$STATE_FILE"

            echo "Still FAIL count=$FAIL"

            if [[ "$FAIL" -ge 5 ]]; then

                send_tele "$(hostname) $USER CURL FAIL x5"

            fi

            return
        fi
    fi

    # =====================================================
    # ARO OK
    # =====================================================

    if [[ -n "$AROIP" && "$CONN" == "connected" ]]; then

        echo
        echo "ARO OK"

        echo "0" > "$STATE_FILE"

        return
    fi

    # =====================================================
    # ARO FAIL
    # =====================================================

    FAIL=$((FAIL + 1))

    echo
    echo "ARO FAIL count=$FAIL"

    echo "$FAIL" > "$STATE_FILE"

    # FAIL 1-2
    if [[ "$FAIL" -lt 3 ]]; then

        restart_aro "$USER"

        return
    fi

    # FAIL 3-4
    if [[ "$FAIL" -ge 3 && "$FAIL" -lt 5 ]]; then

        hard_restart_user "$USER"

        send_tele "$(hostname) $USER HARD RESTART"

        return
    fi

    # FAIL >=5
    if [[ "$FAIL" -ge 5 ]]; then

        send_tele "$(hostname) $USER NEED MANUAL CHECK"

    fi
}

install_cron() {

    local USER="$1"

    local DELAY
    DELAY=$(( RANDOM % 180 ))

    local SCRIPT
    SCRIPT="$BASE_DIR/watchdog-$USER.sh"

    cat > "$SCRIPT" <<EOF
#!/usr/bin/env bash
sleep $DELAY
$(realpath "$0") run $USER
EOF

    chmod +x "$SCRIPT"

    (
        crontab -l 2>/dev/null | grep -v "watchdog-$USER.sh"
        echo "*/10 * * * * $SCRIPT"
    ) | crontab -

    echo
    echo "Installed cron for $USER"
    echo "Delay: ${DELAY}s"
}

menu() {

    while true; do

        clear

        echo "====================================="
        echo " ARO WATCHDOG FULL"
        echo "====================================="
        echo
        echo "1. Install watchdog user"
        echo "2. Check user now"
        echo "3. View fail count"
        echo "4. Reset fail count"
        echo "5. Exit"
        echo

        read -rp "Choose: " CH

        case "$CH" in

            1)

                echo
                echo "Users:"
                getent passwd | awk -F: '$1 ~ /^aro[0-9]*$/ {print $1}' | sort -V

                echo
                read -rp "Nhap user: " USER

                install_cron "$USER"

                read -rp "Enter..."
                ;;

            2)

                echo
                read -rp "Nhap user: " USER

                check_user "$USER"

                read -rp "Enter..."
                ;;

            3)

                echo
                read -rp "Nhap user: " USER

                cat "$BASE_DIR/${USER}.state" 2>/dev/null || echo 0

                read -rp "Enter..."
                ;;

            4)

                echo
                read -rp "Nhap user: " USER

                echo 0 > "$BASE_DIR/${USER}.state"

                echo "RESET OK"

                read -rp "Enter..."
                ;;

            5)
                exit
                ;;

        esac
    done
}

# =========================================================

if [[ "${1:-}" == "run" ]]; then

    check_user "$2"
    exit
fi

menu
