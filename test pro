#!/usr/bin/env bash
set -u

# ============================================================
# Bulk SOCKS5 Proxy Tester with ID
#
# Input format, one proxy per line:
#   ID|host:port:user:pass
#
# Example:
#   P001|snf5.tunproxy.com:65447:Dz8qWu:Cht0PT4D
#   P002|snf6.tunproxy.com:65448:user2:pass2
#
# Output:
#   proxy-test-result.csv
#   good-proxies.txt
#   ok-proxies.txt
#   bad-proxies.txt
#
# Status:
#   GOOD     = pass all tests, 1 stable IP
#   OK       = >=80% pass, usable but watch
#   ROTATING = pass all but IP changed
#   WEAK     = unstable
#   DEAD     = no pass
# ============================================================

INPUT="${1:-proxies.txt}"
OUT="${2:-proxy-test-result.csv}"
GOOD_OUT="good-proxies.txt"
OK_OUT="ok-proxies.txt"
BAD_OUT="bad-proxies.txt"

TEST_COUNT="${TEST_COUNT:-5}"
TIMEOUT="${TIMEOUT:-12}"
SPEED_BYTES="${SPEED_BYTES:-1000000}"

if [[ ! -f "$INPUT" ]]; then
  echo "Khong tim thay file input: $INPUT"
  echo
  echo "Tao file proxies.txt dang:"
  echo "P001|snf5.tunproxy.com:65447:Dz8qWu:Cht0PT4D"
  exit 1
fi

command -v curl >/dev/null 2>&1 || {
  echo "May chua co curl. Cai bang:"
  echo "sudo apt update && sudo apt install -y curl"
  exit 1
}

echo "id,proxy,status,main_ip,unique_ip_count,pass_count,total_count,time_total_sec,speed_bytes_per_sec,note" > "$OUT"
: > "$GOOD_OUT"
: > "$OK_OUT"
: > "$BAD_OUT"

echo "============================================================"
echo "Bulk SOCKS5 Proxy Tester with ID"
echo "Input : $INPUT"
echo "Output: $OUT"
echo "GOOD  : $GOOD_OUT"
echo "OK    : $OK_OUT"
echo "BAD   : $BAD_OUT"
echo "Tests : $TEST_COUNT lan/proxy"
echo "============================================================"
echo

line_no=0
total_proxy=0
good_count=0
ok_count=0
bad_count=0

while IFS= read -r line || [[ -n "$line" ]]; do
  line_no=$((line_no+1))

  [[ -z "$line" ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue

  if [[ "$line" != *"|"* ]]; then
    echo "Line $line_no: BAD_FORMAT - missing ID|proxy"
    echo "\"\",\"$line\",BAD_FORMAT,,0,0,$TEST_COUNT,,,\"format must be ID|host:port:user:pass\"" >> "$OUT"
    echo "$line # BAD_FORMAT missing ID" >> "$BAD_OUT"
    bad_count=$((bad_count+1))
    continue
  fi

  ID="${line%%|*}"
  PROXY_PART="${line#*|}"

  ID="$(echo "$ID" | xargs)"
  PROXY_PART="$(echo "$PROXY_PART" | xargs)"

  IFS=':' read -r HOST PORT USER PASS EXTRA <<< "$PROXY_PART"

  if [[ -n "${EXTRA:-}" || -z "${ID:-}" || -z "${HOST:-}" || -z "${PORT:-}" || -z "${USER:-}" || -z "${PASS:-}" ]]; then
    echo "Line $line_no: BAD_FORMAT - $line"
    echo "\"$ID\",\"$PROXY_PART\",BAD_FORMAT,,0,0,$TEST_COUNT,,,\"format must be ID|host:port:user:pass\"" >> "$OUT"
    echo "$line # BAD_FORMAT" >> "$BAD_OUT"
    bad_count=$((bad_count+1))
    continue
  fi

  if ! [[ "$PORT" =~ ^[0-9]+$ ]] || (( PORT < 1 || PORT > 65535 )); then
    echo "Line $line_no: BAD_PORT - $line"
    echo "\"$ID\",\"$PROXY_PART\",BAD_PORT,,0,0,$TEST_COUNT,,,\"invalid port\"" >> "$OUT"
    echo "$line # BAD_PORT" >> "$BAD_OUT"
    bad_count=$((bad_count+1))
    continue
  fi

  total_proxy=$((total_proxy+1))
  PROXY_URL="socks5h://${USER}:${PASS}@${HOST}:${PORT}"

  echo "[$ID] Testing ${HOST}:${PORT}:${USER}:***"

  PASS_COUNT=0
  IPS=""

  for i in $(seq 1 "$TEST_COUNT"); do
    IP="$(curl -s --max-time "$TIMEOUT" --proxy "$PROXY_URL" https://api.ipify.org || true)"

    if [[ "$IP" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      PASS_COUNT=$((PASS_COUNT+1))
      IPS="${IPS} ${IP}"
      echo "  $i/$TEST_COUNT: $IP"
    else
      echo "  $i/$TEST_COUNT: FAIL"
    fi

    sleep 1
  done

  MAIN_IP=""
  UNIQUE_IP_COUNT=0

  if [[ -n "$IPS" ]]; then
    MAIN_IP="$(echo "$IPS" | xargs -n1 | sort | uniq -c | sort -nr | awk 'NR==1{print $2}')"
    UNIQUE_IP_COUNT="$(echo "$IPS" | xargs -n1 | sort | uniq | wc -l | tr -d ' ')"
  fi

  SPEED_LINE="$(curl -L -s --max-time 25 --proxy "$PROXY_URL" -o /dev/null -w "%{time_total},%{speed_download}" "https://speed.cloudflare.com/__down?bytes=${SPEED_BYTES}" || true)"
  TIME_TOTAL="$(echo "$SPEED_LINE" | cut -d',' -f1)"
  SPEED="$(echo "$SPEED_LINE" | cut -d',' -f2)"

  STATUS="BAD"
  NOTE=""

  if (( PASS_COUNT == TEST_COUNT )) && [[ "$UNIQUE_IP_COUNT" == "1" ]]; then
    STATUS="GOOD"
    NOTE="stable_ip"
    echo "${ID}|${PROXY_PART}" >> "$GOOD_OUT"
    good_count=$((good_count+1))
  elif (( PASS_COUNT == TEST_COUNT )) && (( UNIQUE_IP_COUNT > 1 )); then
    STATUS="ROTATING"
    NOTE="ip_changed"
    echo "${ID}|${PROXY_PART} # ROTATING ip_changed main_ip=${MAIN_IP}" >> "$BAD_OUT"
    bad_count=$((bad_count+1))
  elif (( PASS_COUNT >= TEST_COUNT * 80 / 100 )); then
    STATUS="OK"
    NOTE="some_fail"
    echo "${ID}|${PROXY_PART}" >> "$OK_OUT"
    ok_count=$((ok_count+1))
  elif (( PASS_COUNT >= 1 )); then
    STATUS="WEAK"
    NOTE="unstable"
    echo "${ID}|${PROXY_PART} # WEAK pass=${PASS_COUNT}/${TEST_COUNT} main_ip=${MAIN_IP}" >> "$BAD_OUT"
    bad_count=$((bad_count+1))
  else
    STATUS="DEAD"
    NOTE="timeout_or_auth_failed"
    echo "${ID}|${PROXY_PART} # DEAD" >> "$BAD_OUT"
    bad_count=$((bad_count+1))
  fi

  echo "\"$ID\",\"$PROXY_PART\",$STATUS,$MAIN_IP,$UNIQUE_IP_COUNT,$PASS_COUNT,$TEST_COUNT,$TIME_TOTAL,$SPEED,\"$NOTE\"" >> "$OUT"

  echo "  => $STATUS | IP=$MAIN_IP | PASS=$PASS_COUNT/$TEST_COUNT | UNIQUE_IP=$UNIQUE_IP_COUNT | SPEED=${SPEED} B/s"
  echo

done < "$INPUT"

echo "============================================================"
echo "XONG."
echo "Tong proxy hop le test: $total_proxy"
echo "GOOD: $good_count"
echo "OK  : $ok_count"
echo "BAD : $bad_count"
echo
echo "Ket qua day du : $OUT"
echo "Proxy GOOD    : $GOOD_OUT"
echo "Proxy OK      : $OK_OUT"
echo "Proxy can ne  : $BAD_OUT"
echo
echo "Xem GOOD:"
echo "cat $GOOD_OUT"
echo
echo "Xem bang day du:"
echo "cat $OUT"
echo "============================================================"
