#!/usr/bin/env bash

clear

echo "==============================="
echo "        ARO TELE SETUP"
echo "==============================="

read -p "Nhap BOT TOKEN: " BOT_TOKEN
read -p "Nhap CHAT ID: " CHAT_ID

echo
echo "Dang test Telegram..."

curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
-d chat_id="$CHAT_ID" \
-d text="вњ… Telegram connected VPS: $(hostname)" \
>/dev/null

echo "OK"
sleep 1

# ==========================
# TAO FILE REPORT
# ==========================

cat > /root/aro-report.sh << 'EOF'
#!/usr/bin/env bash

BOT_TOKEN="REPLACE_BOT_TOKEN"
CHAT_ID="REPLACE_CHAT_ID"

VPS_NAME=$(hostname)
VN_TIME=$(TZ=Asia/Ho_Chi_Minh date '+%Y-%m-%d %H:%M:%S')

PUBLIC_IP=$(curl -4 -s --max-time 10 https://api.ipify.org)

RAM=$(free -h | awk '/Mem:/ {print $3 "/" $2}')
CPU=$(uptime | awk -F'load average:' '{ print $2 }' | cut -d',' -f1)
DISK=$(df -h / | awk 'NR==2 {print $3 "/" $2 " (" $5 ")"}')

MSG="рџљЂ ARO AUTO REPORT

рџ–Ґ VPS : $VPS_NAME
рџЊЌ VPS IP : $PUBLIC_IP
вЏ° Time VN : $VN_TIME

рџ’ѕ RAM : $RAM
рџ”Ґ CPU LOAD : $CPU
рџ“¦ DISK : $DISK

в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

"

TOTAL=0
DOWN=0

for home in /home/*; do

    [[ -d "$home" ]] || continue

    u=$(basename "$home")

    LOG="$home/.local/share/com.aro.ARONetwork/logs/ARO Desktop.log"

    TOTAL=$((TOTAL+1))

    if [[ ! -f "$LOG" ]]; then

        DOWN=$((DOWN+1))

        MSG+="рџ‘¤ $u
рџ”ґ NO LOG

"

        continue
    fi

    CONN=$(grep -o '"connect":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)

    AROIP=$(grep -o '"publicIp":"[^"]*"' "$LOG" 2>/dev/null | tail -1 | cut -d'"' -f4)

    UPTIME=$(grep -o '"uptime":[0-9.]*' "$LOG" 2>/dev/null | tail -1 | cut -d':' -f2)

    AROIP=${AROIP:-"-"}
    UPTIME=${UPTIME:-0}

    STATUS="рџџў ONLINE"

    if [[ "$CONN" != "connected" ]]; then
        STATUS="рџ”ґ DOWN"
        DOWN=$((DOWN+1))
    fi

    MSG+="рџ‘¤ $u
$STATUS
рџЊђ $AROIP
вЏі $UPTIME

"

done

ONLINE=$((TOTAL-DOWN))

MSG+="в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ

рџ“Љ SUMMARY

рџџў ONLINE : $ONLINE
рџ”ґ DOWN : $DOWN
рџ‘Ґ TOTAL : $TOTAL

"

curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
-d chat_id="$CHAT_ID" \
-d text="$MSG" \
-d disable_web_page_preview=true \
>/dev/null
EOF

# ==========================
# THEM TOKEN VA CHAT ID
# ==========================

sed -i "s|REPLACE_BOT_TOKEN|$BOT_TOKEN|g" /root/aro-report.sh
sed -i "s|REPLACE_CHAT_ID|$CHAT_ID|g" /root/aro-report.sh

chmod +x /root/aro-report.sh

# ==========================
# RANDOM 2 LAN / NGAY
# ==========================

crontab -r 2>/dev/null

HOUR1=$((RANDOM % 12))
MIN1=$((RANDOM % 60))

HOUR2=$((12 + RANDOM % 12))
MIN2=$((RANDOM % 60))

(crontab -l 2>/dev/null; echo "$MIN1 $HOUR1 * * * /root/aro-report.sh") | crontab -
(crontab -l 2>/dev/null; echo "$MIN2 $HOUR2 * * * /root/aro-report.sh") | crontab -

echo
echo "==============================="
echo "DONE"
echo "==============================="
echo "Bao cao luc:"
echo "вћЎ $HOUR1:$MIN1"
echo "вћЎ $HOUR2:$MIN2"
echo "==============================="

echo
echo "Dang gui report test..."
bash /root/aro-report.sh
