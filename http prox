#!/bin/bash

echo "===== ARO PROXY MANAGER (HTTP + SOCKS AUTO) ====="

CONFIG="/etc/redsocks.conf"

read -p "Nhập proxy (vd: http://user:pass@ip:port hoặc socks5://...): " PROXY

# Detect type
if [[ $PROXY == http* ]]; then
    TYPE="http-connect"
elif [[ $PROXY == socks5* ]]; then
    TYPE="socks5"
else
    echo "❌ Không nhận dạng được proxy"
    exit 1
fi

# Parse proxy
proto_removed=$(echo $PROXY | sed 's|.*://||')
user=$(echo $proto_removed | cut -d':' -f1)
pass=$(echo $proto_removed | cut -d':' -f2 | cut -d'@' -f1)
ip=$(echo $proto_removed | cut -d'@' -f2 | cut -d':' -f1)
port=$(echo $proto_removed | awk -F: '{print $NF}')

echo
echo "===== PARSED ====="
echo "TYPE: $TYPE"
echo "IP: $ip"
echo "PORT: $port"
echo "USER: $user"

# Backup config
cp $CONFIG ${CONFIG}.bak 2>/dev/null

# Write new config
cat > $CONFIG <<EOF
base {
    log_debug = off;
    log_info = on;
    log = "file:/var/log/redsocks.log";
    daemon = on;
    redirector = iptables;
}

redsocks {
    local_ip = 127.0.0.1;
    local_port = 12345;

    ip = $ip;
    port = $port;

    login = "$user";
    password = "$pass";

    type = $TYPE;
}
EOF

echo
echo "===== RESTART REDSOCKS ====="
systemctl restart redsocks

sleep 2

echo
echo "===== TEST ====="
curl -s https://api.ipify.org
echo

echo "✅ DONE"
