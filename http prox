#!/bin/bash

echo "===== SETUP REDSOCKS2 (HTTP SUPPORT) ====="

# 1. Install redsocks2
echo "[+] Installing redsocks2..."
apt update -y >/dev/null 2>&1
apt install redsocks2 -y

# 2. Stop old redsocks (if exists)
echo "[+] Stopping old redsocks..."
systemctl stop redsocks 2>/dev/null

# 3. Backup config
echo "[+] Backup config..."
cp /etc/redsocks.conf /etc/redsocks.conf.bak 2>/dev/null

# 4. Create new config (HTTP ready)
echo "[+] Writing new config..."

cat > /etc/redsocks.conf << 'EOF'
base {
    log_debug = off;
    log_info = on;
    log = "file:/var/log/redsocks.log";
    daemon = on;
    redirector = iptables;
}

redsocks {
    local_ip = 127.0.0.1;
    local_port = 12345;

    ip = 0.0.0.0;
    port = 0000;

    login = "user";
    password = "pass";

    type = http-connect;
}
EOF

# 5. Fix service to use redsocks2
echo "[+] Updating systemd service..."

SERVICE_FILE="/etc/systemd/system/redsocks.service"

if [ ! -f "$SERVICE_FILE" ]; then
cat > $SERVICE_FILE << 'EOF'
[Unit]
Description=Redsocks Proxy Redirector
After=network.target

[Service]
ExecStart=/usr/bin/redsocks2 -c /etc/redsocks.conf
Restart=always

[Install]
WantedBy=multi-user.target
EOF
else
    sed -i 's|/usr/sbin/redsocks|/usr/bin/redsocks2|g' $SERVICE_FILE
fi

# 6. Reload systemd
echo "[+] Reloading systemd..."
systemctl daemon-reexec
systemctl daemon-reload

# 7. Start service
echo "[+] Starting redsocks2..."
systemctl enable redsocks
systemctl restart redsocks

# 8. Status check
echo
echo "===== STATUS ====="
systemctl status redsocks --no-pager

echo
echo "===== DONE ====="
echo "👉 Bạn chỉ cần sửa /etc/redsocks.conf với proxy thật"
echo "👉 type = http-connect đã sẵn sàng"
